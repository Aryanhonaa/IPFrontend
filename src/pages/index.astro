---
// import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import { IP } from '../components/IP';
import "../styles/global.css"
import "leaflet/dist/leaflet.css";
import Whatitshows from '../components/Whatitshows.jsx';
import CoreConcepts from '../components/CoreConcepts.jsx';
import WhatToDo from '../components/WhatToDo.jsx';
import UseCases from '../components/UserCases.jsx';
import LookUp from '../components/LookUp.jsx';
import Faq from '../components/Faq.jsx';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<IP client:only="react" />
	<Whatitshows client:load />
	<CoreConcepts client:load />
	<WhatToDo client:load />
	<UseCases client:load />
	<LookUp client:load />
	<Faq client:load />
</Layout>
